# Backend Server Settings
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_signing_secret_key

# Google Gemini API Settings (Optional - Fallback to mock AI agent if blank)
GEMINI_API_KEY=your_google_gemini_generative_ai_key

# Firebase Cloud credentials (Optional - Fallback to demo database if blank)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-email@example.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com

# NodeMailer SMTP settings (Optional - Fallback to console logging if blank)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email_username@gmail.com
SMTP_PASS=your_email_app_specific_password
SMTP_FROM="BAMP AI System" <noreply@your-domain.org>
